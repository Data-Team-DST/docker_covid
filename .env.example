# =====================================================
# GITHUB / REGISTRY
# =====================================================
# GITHUB_USER = nom de l'organisation (pour les URLs d'images Docker)
GITHUB_USER=data-team-dst
REGISTRY=ghcr.io

# GHCR_USER  = TON username GitHub PERSONNEL (ex: Steven-Moire, Cirine123...)
#              Utilise pour docker login ghcr.io -u GHCR_USER
# GHCR_TOKEN = TON PAT personnel avec permission read:packages
#              Creer sur : https://github.com/settings/tokens
#              Chaque dev a son propre token. Ne jamais partager ni committer.
GHCR_USER=
GHCR_TOKEN=

# =====================================================
# GLOBAL
# =====================================================
TZ=Europe/Paris
PYTHONUNBUFFERED=1
APP_WORKDIR=/workspace
IMAGE_TAG=latest

# =====================================================
# DOCKERFILES
# =====================================================
TRAINER_DOCKERFILE=docker/trainer/Dockerfile
STREAMLIT_DOCKERFILE=docker/streamlit/Dockerfile

# =====================================================
# IMAGES
# =====================================================
BASE_IMAGE=${REGISTRY}/${GITHUB_USER}/covid-xray-base
TRAINER_IMAGE=${REGISTRY}/${GITHUB_USER}/covid-xray-trainer
STREAMLIT_IMAGE=${REGISTRY}/${GITHUB_USER}/covid-xray-streamlit

MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v2.22.1
POSTGRES_IMAGE=postgres:16
MINIO_IMAGE=minio/minio:latest
MINIO_CLIENT_IMAGE=minio/mc:latest

# =====================================================
# CONTAINERS
# =====================================================
TRAINER_CONTAINER_NAME=covid-xray-trainer
STREAMLIT_CONTAINER_NAME=covid-xray-streamlit
MLFLOW_CONTAINER_NAME=mlflow-server
POSTGRES_CONTAINER_NAME=mlflow-postgres
MINIO_CONTAINER_NAME=minio
MINIO_INIT_CONTAINER_NAME=minio-init

# =====================================================
# PATHS
# =====================================================
DATA_DIR=./data
MODELS_DIR=./models
OUTPUTS_DIR=./outputs

# =====================================================
# PORTS
# =====================================================
TRAINER_PORT=8888
STREAMLIT_PORT=8501
MLFLOW_PORT=5000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =====================================================
# POSTGRES
# =====================================================
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow123
POSTGRES_DB=mlflow

# =====================================================
# MINIO
# =====================================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
AWS_DEFAULT_REGION=us-east-1

# =====================================================
# BUCKETS
# =====================================================
MLFLOW_BUCKET=mlflow
DVC_BUCKET=dvcstore

# =====================================================
# MinIO local agit comme cache local.
# Les services dvc-sync-* font une sync periodique avec le bucket distant.
# =====================================================
REMOTE_S3_ENDPOINT=https://dagshub.com/api/v1/repo-buckets/s3/DST_Data_Team
REMOTE_S3_REGION=us-east-1
REMOTE_S3_ACCESS_KEY=put_token_here
REMOTE_S3_SECRET_KEY=put_token_here
REMOTE_DVC_BUCKET=docker_covid
SYNC_INTERVAL_SECONDS=300N

# Intervalle de sync periodique (en secondes)
SYNC_INTERVAL_SECONDS=300

# Mapping local <-> remote par prefixe
LOCAL_DATASETS_PREFIX=datasets
LOCAL_MODELS_PREFIX=models
LOCAL_OUTPUTS_PREFIX=outputs

REMOTE_DATASETS_PREFIX=datasets
REMOTE_MODELS_PREFIX=models
REMOTE_OUTPUTS_PREFIX=outputs

# =====================================================
# GPU
# all  -> essaie d'exposer le GPU
# void -> CPU seulement
# =====================================================
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# =====================================================
# ML BACKEND (Phase 1 — API d'inférence)
# =====================================================
API_ENV=development
API_VERSION=0.1.0
MODEL_PATH=data/models/best_model.keras
MODEL_VERSION=1.0.0
