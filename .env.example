# =====================================================
# GITHUB / REGISTRY
# =====================================================
GITHUB_USER=Data-Team-DST
REGISTRY=ghcr.io

# =====================================================
# GLOBAL
# =====================================================
TZ=Europe/Paris
PYTHONUNBUFFERED=1
APP_WORKDIR=/workspace
IMAGE_TAG=latest

# =====================================================
# DOCKERFILES
# =====================================================
TRAINER_DOCKERFILE=docker/trainer/Dockerfile
STREAMLIT_DOCKERFILE=docker/streamlit/Dockerfile

# =====================================================
# IMAGES
# =====================================================
BASE_IMAGE=${REGISTRY}/${GITHUB_USER}/covid-xray-base
TRAINER_IMAGE=${REGISTRY}/${GITHUB_USER}/covid-xray-trainer
STREAMLIT_IMAGE=${REGISTRY}/${GITHUB_USER}/covid-xray-streamlit

MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v2.22.1
POSTGRES_IMAGE=postgres:16
MINIO_IMAGE=minio/minio:latest
MINIO_CLIENT_IMAGE=minio/mc:latest

# =====================================================
# CONTAINERS
# =====================================================
TRAINER_CONTAINER_NAME=covid-xray-trainer
STREAMLIT_CONTAINER_NAME=covid-xray-streamlit
MLFLOW_CONTAINER_NAME=mlflow-server
POSTGRES_CONTAINER_NAME=mlflow-postgres
MINIO_CONTAINER_NAME=minio
MINIO_INIT_CONTAINER_NAME=minio-init

# =====================================================
# PATHS
# =====================================================
DATA_DIR=./data
MODELS_DIR=./models
OUTPUTS_DIR=./outputs

# =====================================================
# PORTS
# =====================================================
TRAINER_PORT=8888
STREAMLIT_PORT=8501
MLFLOW_PORT=5000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =====================================================
# POSTGRES
# =====================================================
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow123
POSTGRES_DB=mlflow

# =====================================================
# MINIO
# =====================================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
AWS_DEFAULT_REGION=us-east-1

# =====================================================
# BUCKETS
# =====================================================
MLFLOW_BUCKET=mlflow
DVC_BUCKET=dvcstore

# =====================================================
# GPU
# all  -> essaie d'exposer le GPU
# void -> CPU seulement
# =====================================================
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility